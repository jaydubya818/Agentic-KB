# Agentic-KB environment — copy to .env (gitignored)

# ── Required ────────────────────────────────────────────────────────────────

# Obsidian Vault root (where Sofie writes back).
# Default: ~/Documents/Obsidian Vault
OBSIDIAN_VAULT_ROOT=/Users/jaywest/Documents/Obsidian Vault

# Anthropic API key — required for kb query, kb compile (RLM pipeline)
ANTHROPIC_API_KEY=sk-ant-...

# ── Web app ─────────────────────────────────────────────────────────────────

# Web server port (default 3002)
KB_PORT=3002

# Base URL exposed to MCP / CLI when calling /api/* endpoints
KB_API_URL=http://localhost:3002

# PIN for accessing private wiki content (wiki/personal/**) via web/MCP/CLI
PRIVATE_PIN=

# ── Cost governance ─────────────────────────────────────────────────────────

# Hard cap on Claude API spend per day (USD). kb query refuses past cap.
KB_DAILY_COST_CAP_USD=5

# ── Optional ────────────────────────────────────────────────────────────────

# Suppress first-run env check after initial pass
KB_FIRST_RUN_OK=

# Override KB root (defaults to repo root resolved from cli/kb.js)
KB_ROOT=
