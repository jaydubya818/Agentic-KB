# Dependencies
web/node_modules/
web/.next/
web/.env.local
node_modules/

# Secrets — root .env carries ANTHROPIC_API_KEY etc. Never commit.
.env
.env.local
.env.*.local

# Cost + audit logs (generated per-machine)
logs/api-cost.log

# Graphify temp files
.graphify_*

# macOS
.DS_Store
**/.DS_Store

# Build outputs
web/tsconfig.tsbuildinfo
graphify-out/cache/

# Claude Code session artifacts (generated per-machine)
.claude/*
# …but keep project-level skills versioned (SKILL.md definitions live here)
!.claude/skills/
!.claude/skills/**
# …and project-level slash commands (Foundry: /foundry-ingest, /foundry-compile, /foundry-ask, /foundry-lint)
!.claude/commands/
!.claude/commands/**

# Personal context graph — real seed contains PII (therapy themes, relationships).
# Only seed.example.json (placeholders) is committable.
wiki/personal/context-graph/seed.json
wiki/personal/context-graph/seed.*.local.json

# PIN-protected private layer — plaintext stays local; .enc blobs may commit
wiki/_private/*
!wiki/_private/.enc/
!wiki/_private/.enc/**
