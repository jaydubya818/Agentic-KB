{
  "name": "agentic-kb-root",
  "private": true,
  "version": "1.0.0",
  "description": "Root deps shared across cli/, mcp/, web/, and lib/agent-runtime/",
  "type": "module",
  "dependencies": {
    "chokidar": "^5.0.0",
    "yaml": "^2.8.3"
  },
  "scripts": {
    "test": "node --test tests/agents/*.test.mjs",
    "test:local": "node --test tests/agents/*.test.mjs",
    "test:fuzz": "node --test tests/agents/fuzz-paths.test.mjs",
    "test:snapshots": "node --test tests/agents/context-snapshots.test.mjs",
    "test:snapshots:update": "UPDATE_SNAPSHOTS=1 node --test tests/agents/context-snapshots.test.mjs",
    "pin:init": "node scripts/pin.mjs init",
    "pin:status": "node scripts/pin.mjs status",
    "pin:lock": "node scripts/pin.mjs lock",
    "pin:unlock": "node scripts/pin.mjs unlock",
    "pin:read": "node scripts/pin.mjs read"
  }
}
